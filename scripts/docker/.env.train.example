# Copy to scripts/docker/.env.train and fill in.
# Loaded by compose.train.yml via --env-file.

# ─── Required ──────────────────────────────────────────────────────────────
UR5_REPO_ID=ur5_dataset_20260415
WANDB_API_KEY=

# ─── Recommended ───────────────────────────────────────────────────────────
# HuggingFace token for downloading Pi0.5 base weights.
HF_TOKEN=

# ─── Host paths ────────────────────────────────────────────────────────────
# Override if dataset / checkpoints live outside the repo (e.g. on a fast NVMe).
# Default resolves to <project_root>/dataset and <project_root>/checkpoints.
# DATASET_PATH=/mnt/nvme/openpi_dataset
# CHECKPOINTS_PATH=/mnt/nvme/openpi_checkpoints

# Caches — keep on a fast disk with ≥ 50 GB free.
# UV_CACHE_PATH=$HOME/.cache/uv
# HF_CACHE_PATH=$HOME/.cache/huggingface

# ─── Tuning ────────────────────────────────────────────────────────────────
XLA_PYTHON_CLIENT_MEM_FRACTION=0.95
